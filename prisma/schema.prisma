generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SeriesLifecycleStatus {
  RETURNING
  ENDED
  CANCELED
  IN_PRODUCTION
  PILOT
}

enum WatchState {
  WANT_TO_WATCH
  WATCHING
  PAUSED
  DROPPED
  COMPLETED
}

enum Visibility {
  PUBLIC
  FOLLOWERS
  PRIVATE
}

enum ExternalSource {
  TMDB
}

enum ExternalEntityType {
  SERIES
  SEASON
  EPISODE
}

enum ActivityType {
  EPISODE_WATCHED
  SERIES_STATUS_CHANGED
  SERIES_COMPLETED
  REVIEW_CREATED
  LIST_CREATED
  USER_FOLLOWED
}

enum CatalogSyncType {
  POPULAR_SERIES
  SERIES_DETAILS
  SERIES_SEASONS
  SERIES_EPISODES
  FULL_REFRESH
}

enum CatalogSyncStatus {
  RUNNING
  SUCCESS
  FAILED
  PARTIAL
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum NotificationType {
  NEW_EPISODE_AVAILABLE
  FOLLOWED_YOU
  REVIEW_FROM_FOLLOWING
  LIST_FROM_FOLLOWING
  SERIES_COMPLETED
  ADMIN_NOTICE
  ACHIEVEMENT_UNLOCKED
}

enum AchievementCategory {
  WATCHING
  SOCIAL
  COLLECTION
  STREAK
  REVIEW
  SPECIAL
}

enum AchievementRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

model User {
  id                 String                @id @default(cuid())
  name               String
  username           String                @unique
  email              String                @unique
  passwordHash       String
  avatarUrl          String?
  bio                String?
  role               UserRole              @default(USER)
  lastLoginAt        DateTime?
  isProfilePrivate   Boolean               @default(false)
  showWatchedSeries  Boolean               @default(true)
  showWatchingSeries Boolean               @default(true)
  showLists          Boolean               @default(true)
  showReviews        Boolean               @default(true)
  showActivity       Boolean               @default(true)
  statuses           UserSeriesStatus[]
  episodeProgress    UserEpisodeProgress[]
  followers          Follow[]              @relation("followers")
  following          Follow[]              @relation("following")
  reviews            Review[]
  ratings            Rating[]
  lists              List[]
  activities         Activity[]            @relation("ActivityUser")
  targetedActivities Activity[]            @relation("ActivityTargetUser")
  notifications      Notification[]        @relation("NotificationUser")
  actorNotifications Notification[]        @relation("NotificationActor")
  adminAuditLogs     AdminAuditLog[]
  achievements       UserAchievement[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([role])
}

model Series {
  id               String                  @id @default(cuid())
  slug             String                  @unique
  title            String
  originalTitle    String?
  overview         String?
  posterUrl        String?
  backdropUrl      String?
  firstAirYear     Int?
  language         String?
  network          String?
  genres           String[]
  status           SeriesLifecycleStatus
  popularityScore  Float?
  voteAverage      Float?
  voteCount        Int?
  seasons          Season[]
  reviews          Review[]
  ratings          Rating[]
  statuses         UserSeriesStatus[]
  externalMappings ExternalSourceMapping[]
  listItems        ListItem[]
  activities       Activity[]
  notifications    Notification[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([status])
  @@index([firstAirYear])
  @@index([popularityScore])
  @@index([voteAverage])
  @@index([title])
}

model Season {
  id             String          @id @default(cuid())
  seriesId       String
  number         Int
  title          String
  overview       String?
  posterUrl      String?
  airYear        Int?
  episodeCount   Int             @default(0)
  externalSource ExternalSource?
  externalId     String?
  series         Series          @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  episodes       Episode[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([seriesId, number])
  @@unique([externalSource, externalId])
}

model Episode {
  id             String                @id @default(cuid())
  seasonId       String
  number         Int
  title          String
  overview       String?
  stillUrl       String?
  runtimeMinutes Int?
  airedAt        DateTime?
  externalSource ExternalSource?
  externalId     String?
  season         Season                @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  progress       UserEpisodeProgress[]
  activities     Activity[]
  notifications  Notification[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@unique([seasonId, number])
  @@unique([externalSource, externalId])
}

model UserSeriesStatus {
  id                String     @id @default(cuid())
  userId            String
  seriesId          String
  state             WatchState
  completionPercent Float      @default(0)
  lastActivityAt    DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  series            Series     @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@unique([userId, seriesId])
}

model UserEpisodeProgress {
  id        String    @id @default(cuid())
  userId    String
  episodeId String
  watched   Boolean   @default(false)
  watchedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode   Episode   @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, episodeId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  follower    User     @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("followers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}

model Review {
  id              String         @id @default(cuid())
  userId          String
  seriesId        String
  rating          Int
  body            String
  visibility      Visibility     @default(PUBLIC)
  hiddenByAdminAt DateTime?
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  series          Series         @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  activities      Activity[]
  notifications   Notification[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([userId, seriesId])
}

model Rating {
  id        String   @id @default(cuid())
  userId    String
  seriesId  String
  value     Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  series    Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, seriesId])
}

model List {
  id              String         @id @default(cuid())
  userId          String
  title           String
  description     String?
  visibility      Visibility     @default(PUBLIC)
  hiddenByAdminAt DateTime?
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           ListItem[]
  activities      Activity[]
  notifications   Notification[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model ListItem {
  id        String   @id @default(cuid())
  listId    String
  seriesId  String
  position  Int
  note      String?
  list      List     @relation(fields: [listId], references: [id], onDelete: Cascade)
  series    Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([listId, seriesId])
  @@unique([listId, position])
}

model Notification {
  id            String           @id @default(cuid())
  userId        String
  type          NotificationType
  title         String
  body          String
  href          String?
  readAt        DateTime?
  actorUserId   String?
  seriesId      String?
  episodeId     String?
  reviewId      String?
  listId        String?
  achievementId String?
  metadata      Json?
  user          User             @relation("NotificationUser", fields: [userId], references: [id], onDelete: Cascade)
  actorUser     User?            @relation("NotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  series        Series?          @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  episode       Episode?         @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  review        Review?          @relation(fields: [reviewId], references: [id], onDelete: SetNull)
  list          List?            @relation(fields: [listId], references: [id], onDelete: SetNull)
  achievement   Achievement?     @relation(fields: [achievementId], references: [id], onDelete: SetNull)
  createdAt     DateTime         @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([createdAt])
}

model Activity {
  id           String       @id @default(cuid())
  userId       String
  type         ActivityType
  seriesId     String?
  episodeId    String?
  reviewId     String?
  listId       String?
  targetUserId String?
  metadata     Json?
  visibility   Visibility   @default(PUBLIC)
  user         User         @relation("ActivityUser", fields: [userId], references: [id], onDelete: Cascade)
  series       Series?      @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  episode      Episode?     @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  review       Review?      @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  list         List?        @relation(fields: [listId], references: [id], onDelete: Cascade)
  targetUser   User?        @relation("ActivityTargetUser", fields: [targetUserId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([userId, createdAt])
  @@index([visibility, createdAt])
}

model ExternalSourceMapping {
  id           String             @id @default(cuid())
  seriesId     String
  source       ExternalSource
  entityType   ExternalEntityType @default(SERIES)
  externalId   String
  lastSyncedAt DateTime?
  series       Series             @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([source, entityType, externalId])
}

model CatalogSyncRun {
  id                   String            @id @default(cuid())
  source               ExternalSource    @default(TMDB)
  type                 CatalogSyncType
  status               CatalogSyncStatus @default(RUNNING)
  startedAt            DateTime          @default(now())
  finishedAt           DateTime?
  importedSeriesCount  Int               @default(0)
  updatedSeriesCount   Int               @default(0)
  importedSeasonCount  Int               @default(0)
  updatedSeasonCount   Int               @default(0)
  importedEpisodeCount Int               @default(0)
  updatedEpisodeCount  Int               @default(0)
  errorMessage         String?
  metadata             Json?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([type, startedAt])
  @@index([status])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminUserId String
  action      String
  entity      String
  entityId    String?
  metadata    Json?
  result      String   @default("SUCCESS")
  adminUser   User     @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([adminUserId, createdAt])
  @@index([entity, entityId])
}

/// Prepared for future admin-editable system configuration; read/seed-only this sprint.
model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  public      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// The catalog of unlockable achievements — seeded once (scripts/seed-achievements.ts), read-only at runtime.
/// The gamification engine (lib/gamification) never invents rows here; it only reads this catalog and writes UserAchievement.
model Achievement {
  id            String              @id @default(cuid())
  slug          String              @unique
  name          String
  description   String
  icon          String
  category      AchievementCategory
  rarity        AchievementRarity   @default(COMMON)
  points        Int
  hidden        Boolean             @default(false)
  unlocks       UserAchievement[]
  notifications Notification[]
  createdAt     DateTime            @default(now())
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  metadata      Json?
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
}
